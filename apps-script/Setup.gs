function setupSpreadsheet(){var ss=SpreadsheetApp.openById(SPREADSHEET_ID);Object.keys(SCHEMA).forEach(function(e){var name=e.charAt(0).toUpperCase()+e.slice(1),s=ss.getSheetByName(name);if(!s)s=ss.insertSheet(name);if(s.getLastRow()===0){s.getRange(1,1,1,SCHEMA[e].length).setValues([SCHEMA[e]]);s.setFrozenRows(1);s.getRange(1,1,1,SCHEMA[e].length).setFontWeight('bold').setBackground('#087f8c').setFontColor('#ffffff')}});var s=sheet_('settings');if(s.getLastRow()===1)s.getRange(2,1,6,4).setValues([['APP_NAME','Travel Manager','Tên ứng dụng',now_()],['APP_VERSION','1.0.0','Phiên bản',now_()],['DEFAULT_CURRENCY','VND','Tiền tệ',now_()],['DATE_FORMAT','dd/MM/yyyy','Định dạng ngày',now_()],['TIMEZONE','Asia/Ho_Chi_Minh','Múi giờ',now_()],['API_VERSION','v1','Phiên bản API',now_()]]);return{spreadsheetId:SPREADSHEET_ID,sheets:Object.keys(SCHEMA)}}
function seedDemoData(){var t=create_('trips',{Name:'Đà Nẵng – Hội An',MainDestination:'Đà Nẵng',Country:'Việt Nam',StartDate:'2026-08-01',EndDate:'2026-08-03',Status:'Đã xác nhận',TravelerCount:2,Currency:'VND',PlannedBudget:12000000});create_('itinerary',{TripID:t.TripID,Date:'2026-08-01',StartTime:'09:00',EndTime:'11:00',Title:'Tham quan Ngũ Hành Sơn',ActivityType:'Tham quan'});create_('expenses',{TripID:t.TripID,Date:'2026-08-01',Category:'Di chuyển',Description:'Vé máy bay',Amount:3500000,Currency:'VND',ExpenseType:'Thực tế'});create_('tasks',{TripID:t.TripID,Title:'Mua bảo hiểm du lịch',Category:'Bảo hiểm',Priority:'Cao',Status:'Chưa làm'});create_('packing',{TripID:t.TripID,ItemName:'Hộ chiếu/CCCD',Category:'Giấy tờ',Quantity:1,Unit:'bộ',IsRequired:true});return t}
