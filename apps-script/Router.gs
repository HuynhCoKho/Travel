function route_(r){var a=r.action||'health';if(a==='health')return{version:'1.1.0',status:'ok'};authorize_(r.token);if(a==='setup')return setupSpreadsheet();if(a==='getExchangeRate')return exchangeRate_(r.from,r.to);var e=r.entity?entity_(r.entity):'';if(a==='getSettings')return list_('settings',{});if(a==='getDashboard')return dashboard_(r.tripId);if(a==='list')return list_(e,r);if(a==='get')return get_(e,r.id);if(a==='create')return write_(function(){return create_(e,r.data||{})});if(a==='update')return write_(function(){return update_(e,r.data||{})});if(a==='delete')return write_(function(){return soft_(e,r.id,true)});if(a==='restore')return write_(function(){return soft_(e,r.id,false)});if(a==='duplicateTrip')return write_(function(){return duplicateTrip_(r.id)});if(a==='getTripDetails'||a==='exportTrip')return tripDetails_(r.tripId||r.id);throw apiError_('INVALID_ACTION','Action không hợp lệ')}
function write_(fn){var l=LockService.getScriptLock();if(!l.tryLock(20000))throw apiError_('LOCK_TIMEOUT','Hệ thống đang bận, vui lòng thử lại');try{return fn()}finally{l.releaseLock();CacheService.getScriptCache().removeAll(['dashboard'])}}
