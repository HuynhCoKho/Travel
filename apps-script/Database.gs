function list_(e,p){var a=rows_(e).filter(function(x){return !bool_(x.IsDeleted)});if(p.tripId)a=a.filter(function(x){return x.TripID===p.tripId});return a.map(clean_)}function get_(e,id,deleted){var k=SCHEMA[e][0],x=rows_(e).find(function(r){return r[k]===id&&(deleted||!bool_(r.IsDeleted))});if(!x)throw apiError_('NOT_FOUND','Không tìm thấy dữ liệu');return clean_(x)}function clean_(x){var o={};Object.keys(x).filter(function(k){return k!=='_row'}).forEach(function(k){o[k]=x[k]});return o}
function validate_(e,d){(REQUIRED[e]||[]).forEach(function(k){if(d[k]===undefined||d[k]===null||String(d[k]).trim()==='')throw apiError_('VALIDATION_ERROR','Thiếu trường '+k)});if(e==='trips'&&new Date(d.EndDate)<new Date(d.StartDate))throw apiError_('INVALID_DATE_RANGE','Ngày kết thúc phải sau ngày bắt đầu');if(d.TripID&&e!=='trips'){var trip=get_('trips',d.TripID);if(e==='itinerary'){var day=new Date(d.Date),start=new Date(trip.StartDate),end=new Date(trip.EndDate);if(day<start||day>end)throw apiError_('ITINERARY_OUTSIDE_TRIP','Ngày lịch trình nằm ngoài chuyến đi');if(d.StartTime&&d.EndTime&&d.StartTime>=d.EndTime)throw apiError_('INVALID_TIME_RANGE','Giờ kết thúc phải sau giờ bắt đầu');var key=SCHEMA[e][0];var clash=list_(e,{tripId:d.TripID}).some(function(x){return x[key]!==d[key]&&String(x.Date).slice(0,10)===String(d.Date).slice(0,10)&&d.StartTime<x.EndTime&&d.EndTime>x.StartTime});if(clash)throw apiError_('ITINERARY_OVERLAP','Lịch trình bị trùng thời gian')}}Object.keys(d).forEach(function(k){if(typeof d[k]==='string'&&d[k].length>5000)throw apiError_('VALUE_TOO_LONG',k+' quá dài')})}
function create_(e,d){validate_(e,d);var h=SCHEMA[e],n=now_(),o={};o[h[0]]=id_(e);Object.keys(d).forEach(function(k){if(h.indexOf(k)>-1)o[k]=safe_(d[k])});if(h.indexOf('CreatedAt')>-1)o.CreatedAt=n;if(h.indexOf('UpdatedAt')>-1)o.UpdatedAt=n;if(h.indexOf('IsDeleted')>-1)o.IsDeleted=false;sheet_(e).appendRow(h.map(function(k){return o[k]===undefined?'':o[k]}));log_('create',e,o[h[0]],o.TripID,'SUCCESS');return o}
function update_(e,d){var h=SCHEMA[e],key=h[0],old=get_(e,d[key]),all=rows_(e),row=all.find(function(x){return x[key]===d[key]});validate_(e,Object.assign({},old,d));Object.keys(d).forEach(function(k){if(h.indexOf(k)>-1)old[k]=safe_(d[k])});old.UpdatedAt=now_();sheet_(e).getRange(row._row,1,1,h.length).setValues([h.map(function(k){return old[k]===undefined?'':old[k]})]);log_('update',e,old[key],old.TripID,'SUCCESS');return old}
function soft_(e,id,value){var h=SCHEMA[e],key=h[0],r=rows_(e).find(function(x){return x[key]===id});if(!r)throw apiError_('NOT_FOUND','Không tìm thấy dữ liệu');var c=h.indexOf('IsDeleted')+1;if(!c)throw apiError_('NOT_SUPPORTED','Không hỗ trợ xóa');sheet_(e).getRange(r._row,c).setValue(value);log_(value?'delete':'restore',e,id,r.TripID,'SUCCESS');return {id:id}}
