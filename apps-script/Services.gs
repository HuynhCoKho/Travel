function dashboard_(tripId){var trips=list_('trips',{}),expenses=list_('expenses',tripId?{tripId:tripId}:{}),tasks=list_('tasks',tripId?{tripId:tripId}:{}),packing=list_('packing',tripId?{tripId:tripId}:{});var planned=expenses.filter(function(x){return String(x.ExpenseType).toLowerCase().indexOf('dự')>-1}).reduce(function(s,x){return s+(Number(x.ConvertedAmount)||Number(x.Amount)||0)},0),actual=expenses.filter(function(x){return String(x.ExpenseType).toLowerCase().indexOf('thực')>-1}).reduce(function(s,x){return s+(Number(x.ConvertedAmount)||Number(x.Amount)||0)},0);return{tripCount:trips.length,plannedCost:planned,actualCost:actual,pendingTasks:tasks.filter(function(x){return x.Status!=='Hoàn thành'}).length,unpacked:packing.filter(function(x){return !bool_(x.IsPacked)}).length}}
function exchangeRate_(from,to){from=String(from||'VND').toUpperCase();to=String(to||'VND').toUpperCase();if(from===to)return{from:from,to:to,rate:1,date:now_(),source:'manual'};var res=UrlFetchApp.fetch('https://api.frankfurter.dev/v2/rate/'+encodeURIComponent(from)+'/'+encodeURIComponent(to),{muteHttpExceptions:true});if(res.getResponseCode()!==200)throw apiError_('EXCHANGE_RATE_UNAVAILABLE','Không lấy được tỷ giá; vui lòng nhập thủ công');var data=JSON.parse(res.getContentText());return{from:from,to:to,rate:Number(data.rate),date:data.date,source:'Frankfurter'}}
function duplicateTrip_(id){var t=get_('trips',id);delete t.TripID;t.Name+=' (Bản sao)';return create_('trips',t)}function tripDetails_(id){var out={trip:get_('trips',id)};Object.keys(PREFIX).filter(function(e){return e!=='trips'}).forEach(function(e){out[e]=list_(e,{tripId:id})});return out}
