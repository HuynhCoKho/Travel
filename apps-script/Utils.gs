function now_(){return new Date().toISOString()}function json_(success,message,data,code){return ContentService.createTextOutput(JSON.stringify({success:success,message:message,data:data,errorCode:code,timestamp:now_()})).setMimeType(ContentService.MimeType.JSON)}function safe_(v){if(typeof v==='string'&&/^[=+\-@]/.test(v))return "'"+v;return v}function id_(e){return PREFIX[e]+Utilities.getUuid().replace(/-/g,'').slice(0,16).toUpperCase()}function entity_(e){e=String(e||'').toLowerCase();if(!PREFIX[e])throw apiError_('INVALID_ENTITY','Entity không hợp lệ');return e}function apiError_(code,message){var x=new Error(message);x.code=code;return x}function bool_(v){return v===true||String(v).toUpperCase()==='TRUE'}function sheet_(e){return SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName(e.charAt(0).toUpperCase()+e.slice(1))}function rows_(e){var s=sheet_(e),v=s.getDataRange().getValues(),h=v.shift()||[];return v.map(function(r,i){var o={_row:i+2};h.forEach(function(k,j){o[k]=r[j] instanceof Date?r[j].toISOString():r[j]});return o})}function log_(action,e,id,trip,status,msg){try{sheet_('activitylog').appendRow(['LOG_'+Utilities.getUuid(),now_(),action,e,id||'',trip||'',status,msg||'','Web'])}catch(x){}}
