function now_(){return new Date().toISOString()}function json_(success,message,data,code){return ContentService.createTextOutput(JSON.stringify({success:success,message:message,data:data,errorCode:code,timestamp:now_()})).setMimeType(ContentService.MimeType.JSON)}function safe_(v){if(typeof v==='string'&&/^[=+\-@]/.test(v))return "'"+v;return v}function id_(e){return PREFIX[e]+Utilities.getUuid().replace(/-/g,'').slice(0,16).toUpperCase()}function entity_(e){e=String(e||'').toLowerCase();if(!PREFIX[e])throw apiError_('INVALID_ENTITY','Entity không hợp lệ');return e}function apiError_(code,message){var x=new Error(message);x.code=code;return x}function bool_(v){return v===true||String(v).toUpperCase()==='TRUE'}
var SPREADSHEET_;function spreadsheet_(){return SPREADSHEET_||(SPREADSHEET_=SpreadsheetApp.openById(SPREADSHEET_ID))}function sheet_(e){return spreadsheet_().getSheetByName(e.charAt(0).toUpperCase()+e.slice(1))}
function rows_(e){var cache=CacheService.getScriptCache(),key='rows_v3_'+e,cached=cache.get(key);if(cached)try{return JSON.parse(cached)}catch(ignore){}var dateOnly={StartDate:1,EndDate:1,Date:1,DueDate:1,CheckInDate:1,CheckOutDate:1},s=sheet_(e),lastRow=s.getLastRow(),lastCol=s.getLastColumn();if(!lastRow||!lastCol)return[];var v=s.getRange(1,1,lastRow,lastCol).getValues(),h=v.shift()||[],rows=v.map(function(r,i){var o={_row:i+2};h.forEach(function(k,j){o[k]=r[j] instanceof Date?(dateOnly[k]?Utilities.formatDate(r[j],'Asia/Ho_Chi_Minh','yyyy-MM-dd'):r[j].toISOString()):r[j]});return o});var encoded=JSON.stringify(rows);if(encoded.length<90000)cache.put(key,encoded,300);return rows}
function clearDataCache_(){var keys=[];Object.keys(SCHEMA).forEach(function(e){keys.push('rows_v2_'+e,'rows_v3_'+e)});CacheService.getScriptCache().removeAll(keys)}function log_(action,e,id,trip,status,msg){try{sheet_('activitylog').appendRow(['LOG_'+Utilities.getUuid(),now_(),action,e,id||'',trip||'',status,msg||'','Web'])}catch(x){}}
