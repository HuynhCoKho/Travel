function doGet(e){return handle_(e&&e.parameter||{})}function doPost(e){var p={};try{p=JSON.parse(e.postData.contents||'{}')}catch(x){return json_(false,'JSON không hợp lệ',null,'INVALID_JSON')}return handle_(p)}function handle_(p){try{return json_(true,'Thành công',route_(p))}catch(x){log_('error',p.entity,'',p.tripId,'ERROR',x.message);return json_(false,x.message,null,x.code||'INTERNAL_ERROR')}}
